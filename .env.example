# LLM provider switch: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic API — Haiku 4.5 is the cheapest current Claude model (~$1/$5 per 1M
# input/output tokens), far below Sonnet ($3/$15) or Opus ($5/$25)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI API (used only if LLM_PROVIDER=openai) — GPT-5.4 Mini is a low-cost tier
# (~$0.75/$4.50 per 1M tokens) that still handles narrative summary quality well.
# For even cheaper/lighter-weight, GPT-5.4 Nano (~$0.20/$1.25) also works, at some
# quality cost.
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-5.4-mini

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=3600

# Market data (optional — defaults to local JSON fixtures if unset)
MARKET_DATA_API_KEY=
MARKET_DATA_PROVIDER=iex

# App
LOG_LEVEL=INFO
